#include <stdio.h>

int main() {
    int nums1[] = {4,3,2,3,1};
    int nums2[] = {2,2,5,2,3,6};
    int n = 5, m = 6, i, j, a1 = 0, a2 = 0;

    for(i=0;i<n;i++)
        for(j=0;j<m;j++)
            if(nums1[i]==nums2[j]){ a1++; break; }

    for(i=0;i<m;i++)
        for(j=0;j<n;j++)
            if(nums2[i]==nums1[j]){ a2++; break; }

    printf("[%d,%d]", a1, a2);
}
