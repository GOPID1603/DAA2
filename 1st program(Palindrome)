#include <stdio.h>
#include <string.h>

int main() {
    char s[100];
    int i;

    printf("Enter word: ");
    scanf("%s", s);

    for(i = 0; i < strlen(s)/2; i++)
        if(s[i] != s[strlen(s)-1-i]) {
            printf("%s is not palindrome", s);
            return 0;
        }

    printf("%s is palindrome", s);
    return 0;
}
