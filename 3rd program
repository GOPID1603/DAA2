#include <stdio.h>

int main() {
    int nums[] = {1,2,1};   // change values here
    int n = 3, i, j, k, sum = 0;

    for(i = 0; i < n; i++) {
        int freq[100] = {0}, distinct = 0;
        for(j = i; j < n; j++) {
            if(freq[nums[j]] == 0) distinct++;
            freq[nums[j]]++;
            sum += distinct * distinct;
        }
    }

    printf("%d", sum);
}
