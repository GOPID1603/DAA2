#include <stdio.h>

int main() {
    int arr[] = {-9,3,4,6,8,9,10,30};  // Sorted array
    int n = 8;
    int key = 10;   // change key here
    int low = 0, high = n-1, mid;

    while(low <= high) {
        mid = (low + high) / 2;

        if(arr[mid] == key) {
            printf("Element %d is found at position %d", key, mid+1);
            return 0;
        }
        else if(arr[mid] < key)
            low = mid + 1;
        else
            high = mid - 1;
    }

    printf("Element %d is not found", key);
    return 0;
}
